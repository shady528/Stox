# Google Gemini API (optional — users can bring their own key)
GOOGLE_API_KEY=your_google_api_key_here

# Pinecone Vector Database
PINECONE_API_KEY=your_pinecone_api_key_here
PINECONE_INDEX_NAME=stockbot

# CORS (comma-separated origins)
CORS_ORIGINS=http://localhost:3000

# --- ONLINE MODE (default) ---
# Embedding provider: "google" (cloud) | "local" (hkunlp/instructor-large, ~2GB RAM)
EMBEDDING_PROVIDER=google

# Vector store: "pinecone" (cloud) | "chroma" (local, no API key needed)
VECTOR_STORE=pinecone

# Default LLM when no key is provided by user: "google" | "ollama"
DEFAULT_LLM_PROVIDER=google

# --- OFFLINE MODE (set all three below, leave Pinecone vars blank) ---
# EMBEDDING_PROVIDER=local
# VECTOR_STORE=chroma
# DEFAULT_LLM_PROVIDER=ollama
# OLLAMA_HOST=http://ollama:11434
# OLLAMA_MODEL=llama3
